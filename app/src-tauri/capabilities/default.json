{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissions for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/poster-qr-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-path"
  ]
}
